{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Login Response",
  "type": "object",
  "required": ["message", "authorization"],
  "additionalProperties": false,
  "properties": {
    "message": {
      "type": "string",
      "const": "Login realizado com sucesso"
    },
    "authorization": {
      "type": "string",
      "pattern": "^Bearer .+"
    }
  }
}
