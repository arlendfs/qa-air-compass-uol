{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product Response",
  "type": "object",
  "required": ["nome", "preco", "descricao", "quantidade", "_id"],
  "additionalProperties": false,
  "properties": {
    "nome": {
      "type": "string",
      "minLength": 1
    },
    "preco": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "descricao": {
      "type": "string",
      "minLength": 1
    },
    "quantidade": {
      "type": "integer",
      "minimum": 0
    },
    "_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
