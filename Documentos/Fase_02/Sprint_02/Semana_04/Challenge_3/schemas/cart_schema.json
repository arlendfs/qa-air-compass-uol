{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cart Response",
  "type": "object",
  "required": ["produtos", "precoTotal", "quantidadeTotal", "idUsuario", "_id"],
  "additionalProperties": false,
  "properties": {
    "produtos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["idProduto", "quantidade", "precoUnitario"],
        "additionalProperties": false,
        "properties": {
          "idProduto": {
            "type": "string",
            "minLength": 1
          },
          "quantidade": {
            "type": "integer",
            "minimum": 1
          },
          "precoUnitario": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "precoTotal": {
      "type": "number",
      "minimum": 0
    },
    "quantidadeTotal": {
      "type": "integer",
      "minimum": 1
    },
    "idUsuario": {
      "type": "string",
      "minLength": 1
    },
    "_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
